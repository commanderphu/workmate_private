# ==============================
# Workmate Private – Environment
# ==============================

# Datenbank (Prod: PostgreSQL, Dev: SQLite möglich)
DATABASE_URL=postgresql+psycopg2://workmate_private:CHANGE_ME@postgres:5432/workmate_private
POSTGRES_PASSWORD=CHANGE_ME

# Security
SECRET_KEY=CHANGE_ME_min_32_zeichen_lang
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
CLAUDE_API_KEY=sk-ant-...

# CORS (kommagetrennt oder JSON-Array)
ALLOWED_ORIGINS=["https://workmate-private.phudevelopement.xyz"]

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://workmate-private.phudevelopement.xyz/api/v1/calendar/oauth/google/callback

# Firebase Push Notifications
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# App
DEBUG=false
ENVIRONMENT=production
